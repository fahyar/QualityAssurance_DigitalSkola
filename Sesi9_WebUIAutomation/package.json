{
    "name" : "selenium-ui-webdriver",
    "version" : "1.0.0",
    "description": "Selenium webdriver tests using mocha",
    "script" : {
        "test" : "mocha tests --recursive --timeout 600000",
        "test:ui" : "mocha tests/ui --recursive --timeout 600000",
        "jalanin-mochawesome" : "mocha tests --recursive --timeout 600000 --reporter mochawesome",
        "jalanin-simple-html" : "mocha tests --recursive --timeout 60000 --reporter mocha-simple-html-mocha"

    },
    "dependencies": {
        "selenium" : "web-driver"
    },
    "devDependencies": {
        "mocha": "^10.4.0",
        "mochawesome" : "7.1.3",
        "mocha-simple-html-reporter": "^2.0.0"
    }
}